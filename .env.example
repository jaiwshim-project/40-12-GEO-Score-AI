# Gemini AI API Key (필수)
GEMINI_API_KEY=your_gemini_api_key_here

# Admin Password (관리 대시보드 로그인)
ADMIN_DASH_PASS=your_admin_password

# GEO-AIO 연결 URL (계약 전환)
GEO_AIO_URL=https://geo-aio.vercel.app

# Supabase (진단 결과 저장 + 관리 대시보드)
# 1. https://supabase.com 에서 프로젝트 생성
# 2. SQL Editor → supabase/schema.sql 실행
# 3. Settings → API → 다음 두 값 복사
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
